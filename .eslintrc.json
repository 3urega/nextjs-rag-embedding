{
  "extends": ["next/core-web-vitals", "eslint-config-codely/typescript"],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx"],
      "parserOptions": {
        "project": ["./tsconfig.json"]
      }
    },
    {
      "files": ["src/app/scripts/*.mjs"],
      "rules": {
        "no-console": "off",
        "no-await-in-loop": "off"
      }
    }
  ]
}
