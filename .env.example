# --- Web / API ---
NEXT_PUBLIC_API_URL=http://localhost:3000

# Build estático para Capacitor (solo al ejecutar build móvil; no en `next dev`)
# CAPACITOR_STATIC=1

# Capacitor (opcional; por defecto capacitor.config.ts)
# CAPACITOR_APP_ID=com.example.starter
# CAPACITOR_APP_NAME=Starter

# --- Postgres (override del compose local) ---
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=codely
# POSTGRES_PASSWORD=c0d3ly7v
# POSTGRES_DB=postgres

# --- Google Play Billing (servidor) ---
# GOOGLE_PLAY_PACKAGE_NAME=com.example.starter
# JSON de cuenta de servicio (una línea o multilínea escapada)
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# IDs de producto de suscripción separados por coma (cliente)
# GOOGLE_PLAY_SUBSCRIPTION_PRODUCT_IDS=premium_monthly

# --- Auth (futuro) ---
# AUTH_SECRET=

# --- AdMob (cuando integres el plugin) ---
# ADMOB_REWARDED_AD_UNIT_ID=
