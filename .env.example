# --- Web / API ---
NEXT_PUBLIC_API_URL=http://localhost:3000

# Sesión JWT (obligatorio para auth; mín. 16 caracteres)
AUTH_SECRET=change-me-to-a-long-random-string

# Demo billing en local (toggle plan FREE/PREMIUM sin Google Play)
ALLOW_DEMO_BILLING=1

# Build estático para Capacitor (solo al ejecutar build móvil)
# CAPACITOR_STATIC=1

# Capacitor
# CAPACITOR_APP_ID=com.example.starter
# CAPACITOR_APP_NAME=Starter

# --- Postgres (compose local) ---
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=codely
# POSTGRES_PASSWORD=c0d3ly7v
# POSTGRES_DB=postgres

# --- Google Play Billing (servidor) ---
# GOOGLE_PLAY_PACKAGE_NAME=com.example.starter
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_PLAY_SUBSCRIPTION_PRODUCT_IDS=premium_monthly

# --- AdMob (cuando integres el plugin) ---
# ADMOB_REWARDED_AD_UNIT_ID=
